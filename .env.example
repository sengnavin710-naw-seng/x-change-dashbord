# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-with-a-local-password
POSTGRES_PORT=5433
DATABASE_URL=postgresql://app:replace-with-a-local-password@localhost:5433/app
TEST_DATABASE_URL=postgresql://app:replace-with-a-local-password@localhost:5433/app_test

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters-long

# S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=replace-with-a-bucket-name
S3_ACCESS_KEY_ID=replace-with-an-access-key
S3_SECRET_ACCESS_KEY=replace-with-a-secret-key
S3_FORCE_PATH_STYLE=true
