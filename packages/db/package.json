{
  "name": "@repo/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./migrate": "./src/migrate.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/migrate-cli.ts",
    "db:push": "bun --env-file=../../.env src/push-database.ts",
    "db:push:test": "bun --env-file=../../.env src/prepare-test-database.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/bun": "^1.3.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.0.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.8.0"
  }
}
